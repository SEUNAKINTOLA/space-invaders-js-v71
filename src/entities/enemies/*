def create_enemy(enemy_type: str, position: Position) -> Enemy:
    """
    Factory function to create enemies of specified type.

    Args:
        enemy_type: Type of enemy to create
        position: Initial position for the enemy

    Returns:
        Enemy: New enemy instance

    Raises:
        ValueError: If enemy_type is not recognized
    """
    enemy_classes = {
        "basic": BasicEnemy,
        "fast": FastEnemy,
        "tank": TankEnemy
    }

    if enemy_type not in enemy_classes:
        raise ValueError(f"Unknown enemy type: {enemy_type}")

    return enemy_classes[enemy_type](position)